// Auto-generated API client for {{ model.name }}

const BASE_URL = 'http://localhost:8000';

{% for entity in model.entities %}
// ==========================================
// {{ entity.name }} API
// ==========================================
export async function fetch{{ entity.name }}s(): Promise<any[]> {
    const res = await fetch(`${BASE_URL}/{{ entity.table_name }}`);
    if (!res.ok) throw new Error(`Failed to fetch {{ entity.table_name }}: ${res.status}`);
    return res.json();
}

export async function fetch{{ entity.name }}(id: number): Promise<any> {
    const res = await fetch(`${BASE_URL}/{{ entity.table_name }}/${id}`);
    if (!res.ok) throw new Error(`Failed to fetch {{ entity.name }}: ${res.status}`);
    return res.json();
}

export async function create{{ entity.name }}(data: any): Promise<any> {
    const res = await fetch(`${BASE_URL}/{{ entity.table_name }}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
    });
    if (!res.ok) {
        const err = await res.json().catch(() => ({ detail: `HTTP ${res.status}` }));
        throw new Error(err.detail || `Failed to create {{ entity.name }}`);
    }
    return res.json();
}

export async function update{{ entity.name }}(id: number, data: any): Promise<any> {
    const res = await fetch(`${BASE_URL}/{{ entity.table_name }}/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
    });
    if (!res.ok) {
        const err = await res.json().catch(() => ({ detail: `HTTP ${res.status}` }));
        throw new Error(err.detail || `Failed to update {{ entity.name }}`);
    }
    return res.json();
}

export async function delete{{ entity.name }}(id: number): Promise<void> {
    const res = await fetch(`${BASE_URL}/{{ entity.table_name }}/${id}`, {
        method: 'DELETE',
    });
    if (!res.ok) throw new Error(`Failed to delete {{ entity.name }}: ${res.status}`);
}

{% endfor %}
