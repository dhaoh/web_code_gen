{% raw %}import React from 'react';
import { BrowserRouter, Routes, Route, Link } from 'react-router-dom';
{% endraw %}
{% for entity in model.entities %}
import {{ entity.name }}ListPage from './pages/{{ entity.name }}ListPage';
import {{ entity.name }}FormPage from './pages/{{ entity.name }}FormPage';
{% endfor %}

function App() {
    return (
        <BrowserRouter>
            <div className="min-h-screen bg-gray-50">
                <nav className="bg-white shadow-sm border-b">
                    <div className="max-w-6xl mx-auto flex gap-6 p-4">
                        <Link to="/" className="font-bold text-lg">
                            {{ model.name | replace('_', ' ') | title }}
                        </Link>
{% for entity in model.entities %}
                        <Link to="/{{ entity.table_name }}" className="text-gray-600 hover:text-gray-900">
                            {{ entity.name | to_title }}
                        </Link>
{% endfor %}
                    </div>
                </nav>
                <main className="max-w-6xl mx-auto">
                    <Routes>
                        <Route path="/" element={<HomePage />} />
{% for entity in model.entities %}
                        <Route path="/{{ entity.table_name }}" element={<{{ entity.name }}ListPage />} />
                        <Route path="/{{ entity.table_name }}/new" element={<{{ entity.name }}FormPage />} />
                        <Route path="/{{ entity.table_name }}/:id/edit" element={<{{ entity.name }}FormPage />} />
{% endfor %}
                    </Routes>
                </main>
            </div>
        </BrowserRouter>
    );
}

function HomePage() {
    return (
        <div className="p-8">
            <h1 className="text-3xl font-bold mb-4">{{ model.name | replace('_', ' ') | title }}</h1>
            <p className="text-gray-600 mb-6">{{ model.description }}</p>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
{% for entity in model.entities %}
                <Link
                    to="/{{ entity.table_name }}"
                    className="block p-4 bg-white rounded-lg shadow hover:shadow-md transition"
                >
                    <h2 className="text-xl font-semibold">{{ entity.name | to_title }}s</h2>
                    <p className="text-gray-500 text-sm mt-1">
                        {{ entity.attributes | length }} fields
                        {% if entity.attributes | selectattr('primary_key') | first %}
                        (ID: {{ (entity.attributes | selectattr('primary_key') | first).name }})
                        {% endif %}
                    </p>
                </Link>
{% endfor %}
            </div>
        </div>
    );
}

export default App;
