import { BrowserRouter, Routes, Route, NavLink } from 'react-router-dom';
{% for entity in model.entities %}
import {{ entity.name }}ListPage from './pages/{{ entity.name }}ListPage';
import {{ entity.name }}FormPage from './pages/{{ entity.name }}FormPage';
{% endfor %}

const API_BASE = 'http://localhost:8000';

function App() {
    return (
        <BrowserRouter>
            <div className="flex h-screen overflow-hidden">
                {/* Sidebar */}
                <aside className="w-64 bg-slate-900 text-white flex flex-col shrink-0">
                    <div className="p-5 border-b border-slate-700">
                        <h1 className="text-lg font-bold tracking-tight">
                            ⚙️ {{ model.name | replace('_', ' ') | title }}
                        </h1>
                    </div>
                    <nav className="flex-1 overflow-y-auto p-3 space-y-1">
                        <NavLink
                            to="/"
                            end
                            className={({ isActive }) =>
                                `flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition ${
                                    isActive ? 'bg-indigo-600 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white'
                                }`
                            }
                        >
                            <span className="text-base">🏠</span> Dashboard
                        </NavLink>
{% for entity in model.entities %}
                        <NavLink
                            to="/{{ entity.table_name }}"
                            className={({ isActive }) =>
                                `flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition ${
                                    isActive ? 'bg-indigo-600 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white'
                                }`
                            }
                        >
                            <span className="text-base">{{ entity.name | to_title }}</span>
                        </NavLink>
{% endfor %}
                    </nav>
                    <div className="p-4 border-t border-slate-700 text-xs text-slate-500">
                        Generated via Model-Driven Approach
                    </div>
                </aside>

                {/* Main content */}
                <main className="flex-1 overflow-y-auto bg-slate-100">
                    <Routes>
                        <Route path="/" element={<Dashboard />} />
{% for entity in model.entities %}
                        <Route path="/{{ entity.table_name }}" element={<{{ entity.name }}ListPage apiBaseUrl={API_BASE} />} />
                        <Route path="/{{ entity.table_name }}/new" element={<{{ entity.name }}FormPage />} />
                        <Route path="/{{ entity.table_name }}/:id/edit" element={<{{ entity.name }}FormPage />} />
{% endfor %}
                    </Routes>
                </main>
            </div>
        </BrowserRouter>
    );
}

function Dashboard() {
    return (
        <div className="p-8">
            <div className="mb-8">
                <h1 className="text-3xl font-bold text-slate-900">Dashboard</h1>
                <p className="text-slate-500 mt-1">{{ model.description | truncate(150) }}</p>
            </div>

            {/* Stats */}
            <div className="grid grid-cols-3 gap-5 mb-8">
{% for entity in model.entities %}
                <div className="bg-white rounded-xl shadow-sm border border-slate-200 p-5 hover:shadow-md transition">
                    <div className="flex items-center justify-between mb-3">
                        <span className="text-2xl">{{ entity.name | to_title }}</span>
                        <span className="text-3xl">
{% if 'student' in entity.name.lower() %}👤{% elif 'course' in entity.name.lower() %}📚{% elif 'enrollment' in entity.name.lower() %}📋{% elif 'user' in entity.name.lower() %}👥{% elif 'department' in entity.name.lower() %}🏛️{% elif 'grade' in entity.name.lower() %}📊{% elif 'teacher' in entity.name.lower() %}👨‍🏫{% elif 'assignment' in entity.name.lower() %}📝{% elif 'classroom' in entity.name.lower() %}🏫{% elif 'schedule' in entity.name.lower() %}📅{% else %}📦{% endif %}
                        </span>
                    </div>
                    <p className="text-xs text-slate-400 mb-3">
                        {{ entity.attributes | length }} attribute{% if entity.attributes | length != 1 %}s{% endif %}
                        {% if entity.relationships %}&middot; {{ entity.relationships | length }} relation{% if entity.relationships | length != 1 %}s{% endif %}{% endif %}
                    </p>
                    <a
                        href="/{{ entity.table_name }}"
                        className="inline-flex items-center gap-1 text-sm font-medium text-indigo-600 hover:text-indigo-800 transition"
                    >
                        Manage <span className="text-xs">→</span>
                    </a>
                </div>
{% endfor %}
            </div>

            {/* Business Rules */}
            <div className="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h2 className="text-lg font-semibold text-slate-900 mb-4">🏷️ Business Rules</h2>
                <div className="space-y-3">
{% for rule in model.business_rules %}
{% if rule.severity.value == 'critical' %}
{% set dot_color = 'bg-red-500' %}
{% set badge_color = 'bg-red-100 text-red-700' %}
{% elif rule.severity.value == 'important' %}
{% set dot_color = 'bg-amber-500' %}
{% set badge_color = 'bg-amber-100 text-amber-700' %}
{% else %}
{% set dot_color = 'bg-blue-400' %}
{% set badge_color = 'bg-blue-100 text-blue-700' %}
{% endif %}
                    <div className="flex items-start gap-3 p-3 bg-slate-50 rounded-lg">
                        <span className={`mt-0.5 w-2 h-2 rounded-full shrink-0 {{ dot_color }}`}></span>
                        <div>
                            <span className="text-sm font-semibold text-slate-800">{{ rule.name | replace('_', ' ') | title }}</span>
                            <span className={`ml-2 text-[10px] px-1.5 py-0.5 rounded-full font-medium uppercase {{ badge_color }}`}>{{ rule.severity.value }}</span>
                            <p className="text-xs text-slate-500 mt-0.5">{{ rule.description | truncate(200) }}</p>
                        </div>
                    </div>
{% endfor %}
                </div>
            </div>
        </div>
    );
}

export default App;
